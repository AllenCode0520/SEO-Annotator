{
  "name": "annotator-robot",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Workflow-friendly claim annotator that writes fixed-schema comments[] without mutating article body content.",
  "bin": {
    "annotator-robot": "./src/cli.js"
  },
  "scripts": {
    "annotate:json": "node ./src/cli.js annotate-json",
    "annotate:run-once": "node --env-file=.env ./src/cli.js run-once",
    "cleanup:stale": "node --env-file=.env ./src/cli.js cleanup-stale",
    "test": "node --test"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "optionalDependencies": {
    "playwright": "^1.48.0"
  },
  "engines": {
    "node": ">=20"
  }
}
